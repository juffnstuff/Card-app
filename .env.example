# Database — PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/cardkeeper?schema=public"

# JWT secret — change this to a long random string in production
JWT_SECRET="change-me-to-a-real-secret"

# Server port
PORT=3001

# Email (Nodemailer) — stub config, swap with SendGrid credentials for production
SMTP_HOST="smtp.ethereal.email"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="reminders@cardkeeper.app"

# Amazon Associates affiliate tag — earn commission on card purchases
# Sign up at https://affiliate-program.amazon.com
AMAZON_AFFILIATE_TAG="cardkeeper-20"

# Frontend URL (for CORS and email links)
FRONTEND_URL="http://localhost:5173"
