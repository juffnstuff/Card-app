# Database — PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/cardkeeper?schema=public"

# JWT secret — change this to a long random string in production
JWT_SECRET="change-me-to-a-real-secret"

# Server port
PORT=3001

# Email (Nodemailer) — stub config, swap with SendGrid credentials for production
SMTP_HOST="smtp.ethereal.email"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="reminders@cardkeeper.app"

# Amazon Associates affiliate tag — earn commission on card purchases
# Sign up at https://affiliate-program.amazon.com
AMAZON_AFFILIATE_TAG="cardkeeper-20"

# Stripe — subscription billing for Plus plan
# Sign up at https://dashboard.stripe.com
STRIPE_SECRET_KEY=""
STRIPE_PRICE_ID_MONTHLY=""
STRIPE_PRICE_ID_YEARLY=""
STRIPE_WEBHOOK_SECRET=""

# Google OAuth — for importing contacts and birthdays
# Set up at https://console.cloud.google.com/apis/credentials
# Enable "People API" in your Google Cloud project
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:5173/import"

# Google Maps — address autocomplete on profile page
# Enable "Places API" in your Google Cloud project
# Restrict the key to "Places API" and your domain for security
GOOGLE_MAPS_API_KEY=""

# Anthropic — AI-powered card recommendations using Claude
# Sign up at https://console.anthropic.com
ANTHROPIC_API_KEY=""

# Frontend URL (for CORS and email links)
FRONTEND_URL="http://localhost:5173"
