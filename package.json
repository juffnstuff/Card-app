{
  "name": "cardkeeper",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "18.x"
  },
  "scripts": {
    "dev": "concurrently \"pnpm run server\" \"pnpm run client\"",
    "server": "cd server && node index.js",
    "client": "cd client && pnpm exec vite --host",
    "build": "cd client && pnpm install && pnpm exec vite build && cd .. && pnpm exec prisma generate",
    "start": "pnpm exec prisma migrate deploy && node server/index.js",
    "db:migrate": "pnpm exec prisma migrate dev",
    "db:seed": "node prisma/seed.js",
    "db:studio": "pnpm exec prisma studio"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "bcrypt",
      "prisma"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@prisma/client": "^5.22.0",
    "amazon-paapi": "^1.0.7",
    "bcryptjs": "^2.4.3",
    "concurrently": "^9.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "express-rate-limit": "^8.3.2",
    "googleapis": "^171.4.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.16",
    "prisma": "^5.22.0",
    "stripe": "^22.0.0"
  }
}
